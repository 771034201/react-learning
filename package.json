{
  "name": "react-learning",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "React + TypeScript + Vite 学习项目，遵循 IXC 代码规范",
  "author": "IXC Team",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "preview": "vite preview",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "antd": "^6.2.3",
    "mockjs": "^1.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "oxlint": "^0.16.0",
    "prettier": "^3.4.2",
    "terser": "^5.37.0",
    "typescript": "~5.9.3",
    "vite": "^7.2.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "react",
    "typescript",
    "vite",
    "learning",
    "ixc-code-style"
  ]
}
